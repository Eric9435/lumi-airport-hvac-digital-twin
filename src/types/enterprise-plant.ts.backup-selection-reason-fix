export type EnterpriseEquipmentStatus =
  | "running"
  | "stopped"
  | "standby"
  | "starting"
  | "stopping"
  | "fault"
  | "maintenance"
  | "tripped"
  | "unavailable";

export type EnterpriseControlMode =
  "automatic" | "manual" | "off" | "maintenance";

export type TransformerStatus =
  | "off"
  | "energizing"
  | "energized"
  | "tripped"
  | "maintenance"
  | "unavailable";

export type StarterStatus =
  | "stopped"
  | "interlock-check"
  | "main-contactor-engaged"
  | "star-starting"
  | "star-running"
  | "star-delta-transition"
  | "delta-running"
  | "stopping"
  | "tripped";

export type CoolingTowerRole =
  "lead" | "lag" | "assist" | "standby" | "maintenance" | "fault";

export type CoolingTowerRedundancyStatus =
  | "full-redundancy"
  | "redundancy-available"
  | "degraded"
  | "insufficient-capacity";

export type PlantSequenceState =
  | "idle"
  | "calculating-demand"
  | "selecting-equipment"
  | "energizing-transformer"
  | "starting-primary-pump"
  | "proving-evaporator-flow"
  | "starting-condenser-pump"
  | "proving-condenser-flow"
  | "staging-cooling-towers"
  | "starting-star-delta"
  | "starting-chiller"
  | "running"
  | "staging-up"
  | "staging-down"
  | "stopping-group"
  | "degraded"
  | "faulted";

export interface EnterpriseMeter {
  ratedPowerKw: number;
  powerKw: number;
  runtimeSeconds: number;
  totalEnergyKwh: number;
  todayEnergyKwh: number;
  lastStartedAt: string | null;
  lastStoppedAt: string | null;
  startCount: number;
}

export interface TransformerState extends EnterpriseMeter {
  id: string;
  name: string;
  associatedChillerId: string;
  status: TransformerStatus;
  mode: EnterpriseControlMode;
  primaryVoltageKv: number;
  secondaryVoltageV: number;
  ratedCapacityKva: number;
  activePowerKw: number;
  apparentPowerKva: number;
  powerFactor: number;
  loadPercent: number;
  primaryCurrentA: number;
  secondaryCurrentA: number;
  frequencyHz: number;
  oilTemperatureC: number;
  windingTemperatureC: number;
  incomingSupplyAvailable: boolean;
  incomingBreakerClosed: boolean;
  lvBreakerClosed: boolean;
  protectionHealthy: boolean;
  overcurrentTrip: boolean;
  earthFaultTrip: boolean;
  overtemperatureTrip: boolean;
  maintenanceLockout: boolean;
  alarmMessage: string | null;
  selectionReason?: string;
}

export interface StarDeltaStarterState {
  id: string;
  associatedChillerId: string;
  status: StarterStatus;
  mainContactorOn: boolean;
  starContactorOn: boolean;
  deltaContactorOn: boolean;
  overloadHealthy: boolean;
  phaseFailureHealthy: boolean;
  phaseSequenceHealthy: boolean;
  controlVoltageHealthy: boolean;
  sequenceElapsedSeconds: number;
  startRequestedAt: string | null;
  starStartedAt: string | null;
  transitionStartedAt: string | null;
  deltaStartedAt: string | null;
  tripReason: string | null;
  lastSequenceStep: string;
}

export interface EnterprisePumpState extends EnterpriseMeter {
  id: string;
  name: string;
  category: "primary" | "secondary" | "condenser";
  associatedChillerId: string | null;
  status: EnterpriseEquipmentStatus;
  mode: EnterpriseControlMode;
  dutyRole: "duty" | "assist" | "standby";
  speedPercent: number;
  flowM3h: number;
  designFlowM3h: number;
  headM: number;
  differentialPressureBar: number;
  currentAmpere: number;
  ratedAmpere: number;
  flowProven: boolean;
}

export interface CoolingTowerFanState extends EnterpriseMeter {
  id: string;
  towerId: string;
  status: EnterpriseEquipmentStatus;
  speedPercent: number;
  currentAmpere: number;
  ratedAmpere: number;
  expectedCurrentAmpere: number;
  currentLoadPercent: number;
  beltCondition:
    | "not-evaluated"
    | "normal"
    | "possible-slip-or-low-load"
    | "possible-belt-problem";
  diagnosticMessage: string;
  minimumRuntimeRemainingSeconds: number;
  minimumOffTimeRemainingSeconds: number;
}

export interface CoolingTowerState {
  id: string;
  name: string;
  role: CoolingTowerRole;
  status: EnterpriseEquipmentStatus;
  available: boolean;
  preferredChillerId: string;
  ratedHeatRejectionKw: number;
  currentHeatRejectionKw: number;
  enteringWaterTemperatureC: number;
  leavingWaterTemperatureC: number;
  ambientWetBulbTemperatureC: number;
  approachTemperatureC: number;
  runtimeSeconds: number;
  fans: CoolingTowerFanState[];
  alarmMessage: string | null;
}

export interface ChillerGroupSequence {
  groupId: string;
  chillerId: string;
  transformerId: string;
  primaryPumpId: string;
  condenserPumpId: string;
  starterId: string;
  selected: boolean;
  required: boolean;
  available: boolean;
  status: EnterpriseEquipmentStatus;
  currentStep: string;
  lastCompletedStep: string;
  failedStep: string | null;
  message: string;
}

export interface PlantSequenceEvent {
  id: string;
  timestamp: string;
  sequenceId: string;
  equipmentId: string;
  category:
    | "plant"
    | "electrical"
    | "transformer"
    | "pump"
    | "cooling-tower"
    | "starter"
    | "chiller"
    | "fault";
  action: string;
  result: "success" | "failure" | "information";
  source: "automatic" | "manual";
  message: string;
}

export interface EnterprisePlantConfiguration {
  tariffMmkPerKwh: number;
  usableChillerCapacityPercent: number;
  chillerStageUpThresholdPercent: number;
  chillerStageDownThresholdPercent: number;
  chillerStageUpDelaySeconds: number;
  chillerStageDownDelaySeconds: number;
  minimumChillerRuntimeSeconds: number;
  minimumChillerOffTimeSeconds: number;
  transformerEnergizeSeconds: number;
  transformerNoLoadShutdownDelaySeconds: number;
  primaryPumpPreStartSeconds: number;
  primaryPumpRunOnSeconds: number;
  condenserPumpPreStartSeconds: number;
  condenserPumpRunOnSeconds: number;
  coolingTowerRunOnSeconds: number;
  starDurationSeconds: number;
  starDeltaTransitionSeconds: number;
  coolingTowerFanStageUpDelaySeconds: number;
  coolingTowerFanStageDownDelaySeconds: number;
  minimumFanRuntimeSeconds: number;
  minimumFanOffTimeSeconds: number;
}

export interface EnterprisePlantState {
  timestamp: string;
  automaticControlEnabled: boolean;
  sequenceState: PlantSequenceState;
  currentSequenceId: string;
  currentSequenceMessage: string;
  lastCompletedStep: string;
  failedSequenceStep: string | null;

  occupancy: number;
  outdoorDryBulbTemperatureC: number;
  outdoorWetBulbTemperatureC: number;
  predictedCoolingLoadKw: number;
  coolingDemandPercent: number;
  requiredChillerCount: number;

  totalPlantPowerKw: number;
  totalPlantEnergyKwh: number;
  todayPlantEnergyKwh: number;
  totalElectricityCostMmk: number;
  todayElectricityCostMmk: number;
  plantRuntimeSeconds: number;

  transformers: TransformerState[];
  starters: StarDeltaStarterState[];
  primaryPumps: EnterprisePumpState[];
  secondaryPumps: EnterprisePumpState[];
  condenserPumps: EnterprisePumpState[];
  coolingTowers: CoolingTowerState[];
  groups: ChillerGroupSequence[];
  sequenceEvents: PlantSequenceEvent[];

  coolingTowerRedundancyStatus: CoolingTowerRedundancyStatus;
  configuration: EnterprisePlantConfiguration;
}
